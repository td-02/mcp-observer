#!/bin/sh

if [ "${HAS_FIGLET:-0}" = "1" ] && [ -n "${REAL_FIGLET:-}" ] && [ -x "${REAL_FIGLET}" ]; then
  exec "${REAL_FIGLET}" "$@"
fi

cat <<'EOF'
 __  __  ___ ___ ___  ___  ___ ___ ___
|  \/  |/ __| _ \ __|/ _ \/ __/ _ \ _ \
| |\/| | (__|  _/ _|| (_) \__ \  __/  _/
|_|  |_|\___|_| |___|\___/|___/\___|_|
EOF
